APP_ENV=development
APP_BASE_URL=http://localhost:8000
REDIS_URL=redis://redis:6379/0
RQ_QUEUE_NAME=map_jobs

S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_REGION_NAME=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_PREVIEWS=map-previews
S3_BUCKET_ARTIFACTS=map-artifacts
S3_SECURE=false

PREVIEW_TTL_SECONDS=43200
PREVIEW_RASTER_DPI=120
PREVIEW_NETWORK_TYPE=drive
PREVIEW_INCLUDE_WATER=false
PREVIEW_INCLUDE_PARKS=false
ARTIFACT_TTL_SECONDS=86400
PRESIGNED_URL_TTL_SECONDS=3600

CAPTCHA_REQUIRED=false
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

RATE_LIMIT_PREVIEW_COUNT=20
RATE_LIMIT_PREVIEW_WINDOW_SECONDS=600
RATE_LIMIT_LOCATIONS_COUNT=60
RATE_LIMIT_LOCATIONS_WINDOW_SECONDS=600
RATE_LIMIT_FONTS_COUNT=120
RATE_LIMIT_FONTS_WINDOW_SECONDS=600
RATE_LIMIT_JOBS_COUNT=5
RATE_LIMIT_JOBS_WINDOW_SECONDS=600
RATE_LIMIT_MAX_CONCURRENT_JOBS_PER_IP=2

NOMINATIM_SEARCH_URL=https://nominatim.openstreetmap.org/search
NOMINATIM_USER_AGENT=city-map-poster-generator/1.0
GOOGLE_FONTS_API_URL=https://www.googleapis.com/webfonts/v1/webfonts
GOOGLE_FONTS_API_KEY=
GOOGLE_FONTS_METADATA_URL=https://fonts.google.com/metadata/fonts
GOOGLE_FONTS_CACHE_TTL_SECONDS=86400
