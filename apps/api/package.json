{
  "name": "api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "uv run uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
    "worker": "uv run python -m app.worker",
    "build": "echo 'python service build is docker-managed'",
    "lint": "uv run ruff check app tests",
    "check-types": "uv run pyright app",
    "test": "uv run pytest"
  }
}
